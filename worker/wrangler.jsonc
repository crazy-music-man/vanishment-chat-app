{
  "name": "vanishment-chat-worker",
  "main": "src/index.js",
  "compatibility_date": "2026-07-01",
  "durable_objects": {
    "bindings": [
      { "name": "ROOMS", "class_name": "Room" }
    ]
  },
  // 無料プランでDurable Objectsを使うにはSQLiteバックエンドのクラスが必須
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["Room"] }
  ]
}
